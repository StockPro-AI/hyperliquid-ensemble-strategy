//@version=6
strategy("SMC + VWAP Edge Strategy v6", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=10,
     commission_type=strategy.commission.percent, commission_value=0.05,
     max_bars_back=1000)

// ============================================================
// INPUTS
// ============================================================
i_vwapSrc   = input.string("HL/2", "VWAP Source", options=["HL/2","HLC/3","Close"])
i_showSV    = input.bool(true,  "Show Session VWAP")
i_showWV    = input.bool(true,  "Show Weekly VWAP")
i_showMV    = input.bool(true,  "Show Monthly VWAP")
i_showAV    = input.bool(true,  "Show AVWAP H/L")
i_obLB      = input.int(5,    "Order Block Lookback",  minval=2, maxval=20)
i_fvgPct    = input.float(0.05,"FVG Min Gap %",         minval=0.01, maxval=2.0, step=0.01)
i_fvgLB     = input.int(10,   "FVG Lookback",           minval=3,  maxval=30)
i_minConf   = input.int(2,    "Min Confluence (1-4)",   minval=1, maxval=4)
i_atrLen    = input.int(14,   "ATR Length")
i_slMult    = input.float(1.5, "SL ATR Mult",           minval=0.5, maxval=5.0, step=0.25)
i_rrRatio   = input.float(2.0, "R:R Ratio",             minval=1.0, maxval=6.0, step=0.25)

// ============================================================
// VWAP PRICE BASIS (HL/2 = institutionell bevorzugt)
// ============================================================
vwapPrice = i_vwapSrc == "HL/2" ? hl2 : i_vwapSrc == "HLC/3" ? hlc3 : close

// ============================================================
// SESSION VWAP (Reset daily)
// ============================================================
var float svSum = 0.0
var float svVol = 0.0
if ta.change(time("D")) != 0
    svSum := 0.0
    svVol := 0.0
svSum += vwapPrice * volume
svVol += volume
vwapS = svVol > 0 ? svSum / svVol : na

// ============================================================
// WEEKLY VWAP
// ============================================================
var float wvSum = 0.0
var float wvVol = 0.0
if ta.change(time("W")) != 0
    wvSum := 0.0
    wvVol := 0.0
wvSum += vwapPrice * volume
wvVol += volume
vwapW = wvVol > 0 ? wvSum / wvVol : na

// ============================================================
// MONTHLY VWAP
// ============================================================
var float mvSum = 0.0
var float mvVol = 0.0
if ta.change(time("M")) != 0
    mvSum := 0.0
    mvVol := 0.0
mvSum += vwapPrice * volume
mvVol += volume
vwapM = mvVol > 0 ? mvSum / mvVol : na

// ============================================================
// ANCHORED VWAP from last Swing High / Swing Low
// NOTE: ta.pivothigh/pivotlow require simple int (fixed values)
// ============================================================
var float ahSum = 0.0
var float ahVol = 0.0
var float alSum = 0.0
var float alVol = 0.0

swHigh = ta.pivothigh(high, 10, 10)
swLow  = ta.pivotlow( low,  10, 10)

if not na(swHigh)
    ahSum := 0.0
    ahVol := 0.0
if not na(swLow)
    alSum := 0.0
    alVol := 0.0

ahSum += vwapPrice * volume
ahVol += volume
alSum += vwapPrice * volume
alVol += volume
avwapH = ahVol > 0 ? ahSum / ahVol : na
avwapL = alVol > 0 ? alSum / alVol : na

// ============================================================
// ORDER BLOCKS
// ============================================================
bullOB = false
bearOB = false
n_ob   = math.min(i_obLB, bar_index - 3)
if n_ob >= 2
    for i = 1 to n_ob
        if close[i] < open[i] and close[i-1] > open[i-1] and close[i-1] > open[i]
            bullOB := true
        if close[i] > open[i] and close[i-1] < open[i-1] and close[i-1] < open[i]
            bearOB := true

// ============================================================
// FAIR VALUE GAPS
// ============================================================
bullFVG = false
bearFVG = false
fvgThr  = close * (i_fvgPct / 100.0)
n_fvg   = math.min(i_fvgLB, bar_index - 3)
if n_fvg >= 2
    for j = 1 to n_fvg
        if j >= 2 and low[j-1] > high[j+1] and (low[j-1] - high[j+1]) > fvgThr
            bullFVG := true
        if j >= 2 and high[j-1] < low[j+1] and (low[j+1] - high[j-1]) > fvgThr
            bearFVG := true

// ============================================================
// ATR & VWAP ZONES
// ============================================================
atrVal    = ta.atr(i_atrLen)
aboveVwap = not na(vwapS) and close > vwapS
belowVwap = not na(vwapS) and close < vwapS
nearVwap  = not na(vwapS) and math.abs(close - vwapS) < atrVal * 0.5

// ============================================================
// CONFLUENCE LONG
// ============================================================
longC1 = belowVwap
longC2 = bullFVG
longC3 = bullOB
longC4 = not na(avwapL) and close > avwapL
longScore = (longC1 ? 1 : 0) + (longC2 ? 1 : 0) + (longC3 ? 1 : 0) + (longC4 ? 1 : 0)
longSig   = longScore >= i_minConf

// ============================================================
// CONFLUENCE SHORT
// ============================================================
shortC1 = aboveVwap
shortC2 = bearFVG
shortC3 = bearOB
shortC4 = not na(avwapH) and close < avwapH
shortScore = (shortC1 ? 1 : 0) + (shortC2 ? 1 : 0) + (shortC3 ? 1 : 0) + (shortC4 ? 1 : 0)
shortSig   = shortScore >= i_minConf

// ============================================================
// TRADE EXECUTION
// ============================================================
if longSig and strategy.position_size == 0
    sl = close - atrVal * i_slMult
    tp = close + atrVal * i_slMult * i_rrRatio
    strategy.entry("Long", strategy.long)
    strategy.exit("XL", "Long", stop=sl, limit=tp)

if shortSig and strategy.position_size == 0
    sl = close + atrVal * i_slMult
    tp = close - atrVal * i_slMult * i_rrRatio
    strategy.entry("Short", strategy.short)
    strategy.exit("XS", "Short", stop=sl, limit=tp)

// ============================================================
// PLOTS
// ============================================================
plot(i_showSV ? vwapS : na, "Session VWAP", color.new(color.blue,   0), 2)
plot(i_showWV ? vwapW : na, "Weekly VWAP",  color.new(color.purple, 0), 2)
plot(i_showMV ? vwapM : na, "Monthly VWAP", color.new(color.orange, 0), 2)
plot(i_showAV ? avwapH : na, "AVWAP High",  color.new(color.red,   40), 1, plot.style_stepline)
plot(i_showAV ? avwapL : na, "AVWAP Low",   color.new(color.green, 40), 1, plot.style_stepline)

plotshape(longSig  and strategy.position_size == 0, "Long",  shape.triangleup,   location.belowbar, color.new(color.lime, 0), size=size.small)
plotshape(shortSig and strategy.position_size == 0, "Short", shape.triangledown, location.abovebar, color.new(color.red,  0), size=size.small)

bgcolor(nearVwap ? color.new(color.yellow, 92) : na, title="VWAP Zone")
