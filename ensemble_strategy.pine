//@version=6
strategy("SMC + VWAP Edge Strategy", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=100, commission_type=strategy.commission.percent, commission_value=0.05)

// ═══════════════════════════════════════════════════════════════════════════════════════
// STRATEGY EDGE OVERVIEW
// ═══════════════════════════════════════════════════════════════════════════════════════
// 1. VWAP Mean-Reversion: Institutional positioning anchor (Sharpe 2.1 proven, Concretum 2024)
// 2. LVN Entry Points: Low volume nodes show reduced institutional resistance (temp disabled)
// 3. FVG Fill Rate ~70%: Fair Value Gaps statistically filled 70% of time (SMC research)
// 4. AVWAP Institutional Entry: Anchored VWAP from swing high/low tracks smart money avg entry
// 5. OB+FVG Confluence: Order Block + FVG overlap increases probability (DailyPriceAction 2026)
// ═══════════════════════════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════════════════════

// VWAP Settings
vwap_src = input.string("HL/2", "VWAP Source", options=["HLC/3", "HL/2", "Close"])
show_vwap_session = input.bool(true, "Show Session VWAP")
show_vwap_weekly = input.bool(true, "Show Weekly VWAP")
show_vwap_monthly = input.bool(true, "Show Monthly VWAP")
show_avwap = input.bool(true, "Show Anchored VWAP")
avwap_lookback = input.int(100, "AVWAP Swing Lookback", minval=10, maxval=500)

// Volume Profile / LVN Settings
vp_lookback = input.int(50, "Volume Profile Lookback", minval=10, maxval=200)
lvn_threshold_pct = input.float(0.3, "LVN Threshold (% of max volume)", minval=0.1, maxval=0.8, step=0.05)

// SMC Settings (Order Blocks, Fair Value Gaps)
ob_lookback = input.int(10, "Order Block Lookback", minval=3, maxval=50)
fvg_min_gap_pct = input.float(0.1, "FVG Min Gap (% of price)", minval=0.05, maxval=1.0, step=0.05)
fvg_lookback = input.int(20, "FVG Lookback", minval=5, maxval=100)

// Entry Logic
entry_min_confluence = input.int(3, "Min Confluence Signals (of 5)", minval=2, maxval=5)

// Risk Management
rr_target = input.float(2.0, "Risk:Reward Target", minval=1.0, maxval=5.0, step=0.5)
stop_atr_mult = input.float(1.5, "Stop-Loss ATR Multiplier", minval=0.5, maxval=5.0, step=0.5)
atr_len = input.int(14, "ATR Length")

// ═══════════════════════════════════════════════════════════════════════════════════════
// VWAP CALCULATIONS (HL/2 for better institutional tracking)
// ═══════════════════════════════════════════════════════════════════════════════════════

vwap_price = vwap_src == "HL/2" ? hl2 : vwap_src == "HLC/3" ? hlc3 : close

// Session VWAP
var float vwap_session_sum = 0.0
var float vwap_session_vol = 0.0
if ta.change(time("D")) != 0
    vwap_session_sum := 0.0
    vwap_session_vol := 0.0
vwap_session_sum += vwap_price * volume
vwap_session_vol += volume
vwap_session = vwap_session_vol > 0 ? vwap_session_sum / vwap_session_vol : na

// Weekly VWAP
var float vwap_week_sum = 0.0
var float vwap_week_vol = 0.0
if ta.change(time("W")) != 0
    vwap_week_sum := 0.0
    vwap_week_vol := 0.0
vwap_week_sum += vwap_price * volume
vwap_week_vol += volume
vwap_week = vwap_week_vol > 0 ? vwap_week_sum / vwap_week_vol : na

// Monthly VWAP
var float vwap_month_sum = 0.0
var float vwap_month_vol = 0.0
if ta.change(time("M")) != 0
    vwap_month_sum := 0.0
    vwap_month_vol := 0.0
vwap_month_sum += vwap_price * volume
vwap_month_vol += volume
vwap_month = vwap_month_vol > 0 ? vwap_month_sum / vwap_month_vol : na

// Anchored VWAP from swing highs/lows
var float avwap_high_sum = 0.0
var float avwap_high_vol = 0.0
var int avwap_high_start = 0

var float avwap_low_sum = 0.0
var float avwap_low_vol = 0.0
var int avwap_low_start = 0

is_swing_high = ta.pivothigh(high, avwap_lookback / 4, avwap_lookback / 4)
is_swing_low = ta.pivotlow(low, avwap_lookback / 4, avwap_lookback / 4)

if not na(is_swing_high)
    avwap_high_sum := 0.0
    avwap_high_vol := 0.0
    avwap_high_start := bar_index

if not na(is_swing_low)
    avwap_low_sum := 0.0
    avwap_low_vol := 0.0
    avwap_low_start := bar_index

avwap_high_sum += vwap_price * volume
avwap_high_vol += volume
avwap_high = avwap_high_vol > 0 ? avwap_high_sum / avwap_high_vol : na

avwap_low_sum += vwap_price * volume
avwap_low_vol += volume
avwap_low = avwap_low_vol > 0 ? avwap_low_sum / avwap_low_vol : na

// ═══════════════════════════════════════════════════════════════════════════════════════
// SMART MONEY CONCEPTS (Order Blocks, Fair Value Gaps)
// ═══════════════════════════════════════════════════════════════════════════════════════

// Order Blocks Detection
bullish_ob = false
bearish_ob = false

for i = 1 to ob_lookback
    // Bullish OB: Strong down candle followed by reversal up
    if close[i+1] < open[i+1] and close[i] > open[i] and low[i] < low[i+1]
        bullish_ob := true
        break
    // Bearish OB: Strong up candle followed by reversal down  
    if close[i+1] > open[i+1] and close[i] < open[i] and high[i] > high[i+1]
        bearish_ob := true
        break

// Fair Value Gap (FVG) Detection
bullish_fvg = false
bearish_fvg = false
fvg_threshold = close * (fvg_min_gap_pct / 100)

for i = 1 to fvg_lookback
    // Bullish FVG: Gap between bar[i+2].low and bar[i].high
    if i < bar_index - 2
        gap_bull = low[i] - high[i+2]
        if gap_bull > fvg_threshold
            bullish_fvg := true
            break
        // Bearish FVG: Gap between bar[i+2].high and bar[i].low
        gap_bear = low[i+2] - high[i]
        if gap_bear > fvg_threshold
            bearish_fvg := true
            break

// ═══════════════════════════════════════════════════════════════════════════════════════
// CONFLUENCE SCORING & ENTRY LOGIC
// ═══════════════════════════════════════════════════════════════════════════════════════

atr = ta.atr(atr_len)

// Long Confluence Signals
long_conf_1 = close < vwap_session and close < vwap_week  // Price below VWAP (mean reversion)
long_conf_2 = bullish_fvg  // FVG present
long_conf_3 = bullish_ob  // Order Block present
long_conf_4 = close < avwap_low and not na(avwap_low)  // Below anchored VWAP from low
long_conf_5 = close > ta.ema(close, 20)  // Above EMA20 for trend filter

long_confluence_score = (long_conf_1 ? 1 : 0) + (long_conf_2 ? 1 : 0) + (long_conf_3 ? 1 : 0) + (long_conf_4 ? 1 : 0) + (long_conf_5 ? 1 : 0)
long_signal = long_confluence_score >= entry_min_confluence

// Short Confluence Signals
short_conf_1 = close > vwap_session and close > vwap_week  // Price above VWAP (mean reversion)
short_conf_2 = bearish_fvg  // FVG present
short_conf_3 = bearish_ob  // Order Block present
short_conf_4 = close > avwap_high and not na(avwap_high)  // Above anchored VWAP from high
short_conf_5 = close < ta.ema(close, 20)  // Below EMA20 for trend filter

short_confluence_score = (short_conf_1 ? 1 : 0) + (short_conf_2 ? 1 : 0) + (short_conf_3 ? 1 : 0) + (short_conf_4 ? 1 : 0) + (short_conf_5 ? 1 : 0)
short_signal = short_confluence_score >= entry_min_confluence

// ═══════════════════════════════════════════════════════════════════════════════════════
// TRADE EXECUTION
// ═══════════════════════════════════════════════════════════════════════════════════════

if long_signal and strategy.position_size == 0
    stop_loss = close - (atr * stop_atr_mult)
    take_profit = close + (atr * stop_atr_mult * rr_target)
    strategy.entry("Long", strategy.long)
    strategy.exit("Exit Long", "Long", stop=stop_loss, limit=take_profit)

if short_signal and strategy.position_size == 0
    stop_loss = close + (atr * stop_atr_mult)
    take_profit = close - (atr * stop_atr_mult * rr_target)
    strategy.entry("Short", strategy.short)
    strategy.exit("Exit Short", "Short", stop=stop_loss, limit=take_profit)

// ═══════════════════════════════════════════════════════════════════════════════════════
// VISUALIZATION
// ═══════════════════════════════════════════════════════════════════════════════════════

plot(show_vwap_session ? vwap_session : na, "Session VWAP", color.new(color.blue, 0), 2)
plot(show_vwap_weekly ? vwap_week : na, "Weekly VWAP", color.new(color.purple, 0), 2)
plot(show_vwap_monthly ? vwap_month : na, "Monthly VWAP", color.new(color.orange, 0), 2)
plot(show_avwap ? avwap_high : na, "AVWAP High", color.new(color.red, 50), 1)
plot(show_avwap ? avwap_low : na, "AVWAP Low", color.new(color.green, 50), 1)

bgcolor(long_signal ? color.new(color.green, 90) : short_signal ? color.new(color.red, 90) : na)
plotshape(long_signal, "Long Signal", shape.triangleup, location.belowbar, color.new(color.green, 0), size=size.small)
plotshape(short_signal, "Short Signal", shape.triangledown, location.abovebar, color.new(color.red, 0), size=size.small)
